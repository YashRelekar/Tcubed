# =============================================================
#  Jansky — API Keys and Hardware Configuration
# =============================================================
#  Copy this file to .env and fill in your keys/settings.
#
#    cp .env.example .env
#
#  All keys are OPTIONAL. Jansky works without them, but you
#  lose the corresponding feature (see table below).
#
#  ┌────────────────────────┬────────────────────────────────┐
#  │ Variable               │ Feature unlocked               │
#  ├────────────────────────┼────────────────────────────────┤
#  │ OPENWEATHER_API_KEY    │ Live weather lookups           │
#  │ NEWSAPI_KEY            │ Top news headlines             │
#  │ MOONSHOT_API_KEY       │ Cloud AI answers (Kimi K2)     │
#  └────────────────────────┴────────────────────────────────┘
# =============================================================

OPENWEATHER_API_KEY=
NEWSAPI_KEY=
MOONSHOT_API_KEY=

# =============================================================
#  Raspberry Pi 5 Hardware Configuration
# =============================================================
#
#  These control which physical devices Jansky uses.
#  Default values match the XVF3800 mic + Bluetooth speaker
#  setup described in docs/pi5_setup.md.
#
#  Run `arecord -l` to list capture devices.
#  Run `aplay -l`   to list playback devices.
# =============================================================

# Substring of the microphone device name shown by `arecord -l`
# Default: reSpeaker XVF3800 4-Mic Array (USB ID 2886:001a)
# For a generic USB mic the original code used "USB PnP Sound Device"
MIC_NAME=XVF3800

# Substring of the speaker device name shown by `aplay -l`
# For a Bluetooth A2DP speaker on PipeWire use the empty string ""
# to fall back to the system default output, or supply the card name.
# SPEAKER_NAME=  (leave blank → use system default / PipeWire BT sink)
SPEAKER_NAME=

# Camera index for OpenCV (0 = first camera, usually the Pi camera)
# Leave at 0 for the IMX219 MIPI camera on a Pi 5.
CAMERA_INDEX=0

# libcamera device path (leave blank to let libcamera auto-select)
# e.g. /base/soc/i2c0mux/i2c@1/imx219@10
LIBCAMERA_DEVICE=
